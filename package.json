{
  "name": "mirrorfight",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "deev": "npm run dev",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.2.1",
    "vite": "^5.4.10"
  }
}
